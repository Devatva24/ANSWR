{
  "manifest_version": 3,
  "name": "ANSWR",
  "version": "4.0.0",
  "description": "AI form solver. Alt+P to open. No nonsense.",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": [
    "https://docs.google.com/forms/*",
    "https://api.groq.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://docs.google.com/forms/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
